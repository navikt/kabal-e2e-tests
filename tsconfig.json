{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["esnext", "DOM"],
    "sourceMap": true,
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolveJsonModule": false,
    "isolatedModules": true,
    "noEmit": false,
    "rootDir": "./",
    "outDir": "./dist",

    /* Paths */
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["./"]
}
